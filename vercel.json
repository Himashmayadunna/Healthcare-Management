{
  "version": 2,
  "buildCommand": "npm run build",
  "framework": "nextjs",
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ],
  "env": {
    "NEXT_PUBLIC_API_BASE_URL": "@next_public_api_base_url",
    "DB_USER": "@db_user",
    "DB_PASSWORD": "@db_password",
    "DB_CONNECT": "@db_connect",
    "CORS_ORIGIN": "@cors_origin"
  },
  "regions": ["iad1"]
}
